# =========================================================================
# 1. Terraform Official Gitignore
# =========================================================================
# تجاهل الفولدر اللي بيتحمل فيه الـ Providers والموديولات (بيجيب Error لو اترفع)
.terraform/

# تجاهل ملفات الـ State لأنها بتحتوي على بيانات حساسة عن الـ Infra والـ Passwords
*.tfstate
*.tfstate.*

# تجاهل ملفات الـ Crash logs في حال حصل مشكلة في تيرامورم
crash.log
crash.*

# تجاهل ملفات المتغيرات الحساسة (أنت بتستخدم terraform.tfvars للـ Keys والـ Secrets المحلية)
*.tfvars
*.tfvars.json

# تجاهل ملفات الـ Override لو بتعدل كود محلياً من غير ما ترفعه
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# تجاهل ملفات الـ CLI configuration
.terraformrc
terraform.rc


# =========================================================================
# 2. Security & Credentials (هام جداً لحماية حساب AWS)
# =========================================================================
# منع رفع أي ملفات تحتوي على Keys أو شهادات حماية بالخطأ
*.pem
*.key
*.pub
.aws/
credentials
secrets.txt


# =========================================================================
# 3. Operating System Logs & Editors
# =========================================================================
# تجاهل ملفات كاش نظام التشغيل والـ IDEs زي VS Code
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# VS Code settings
.vscode/
*.code-workspace

# JetBrains / IDEA
.idea/


# =========================================================================
# 4. CI/CD & Local Testing (اختياري وحسب الحاجة)
# =========================================================================
# لو بتسيف لوجات محلياً من الـ GitHub Actions أو التست
.github/**/*.log